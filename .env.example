# Copy to .env on the Server Host only. Never commit the real .env.
DEEPBOX_ENV=production
DEEPBOX_SECRET=replace-with-a-long-random-value
DEEPBOX_DATABASE_URL=sqlite:///C:/deepbox-data/deepbox.db
DEEPBOX_DATA_DIR=C:/deepbox-data

# The HTTPS URL printed by `tailscale serve` (no trailing slash).
DEEPBOX_PUBLIC_URL=https://your-server.your-tailnet.ts.net
DEEPBOX_ALLOWED_ORIGINS=https://your-server.your-tailnet.ts.net
DEEPBOX_COOKIE_SECURE=true
DEEPBOX_COOKIE_SAMESITE=lax

# Uvicorn stays loopback-only; Tailscale Serve is the TLS/WSS entry point.
DEEPBOX_HOST=127.0.0.1
DEEPBOX_PORT=8077

# Deployment platform: local (default; laptop / Tailscale) or azure-app-service.
# Only azure-app-service is permitted to bind 0.0.0.0 in production.
DEEPBOX_PLATFORM=local
# Trusted reverse-proxy hops for uvicorn X-Forwarded-* handling.
# Defaults to 127.0.0.1 (local) / * (azure-app-service).
DEEPBOX_FORWARDED_ALLOW_IPS=127.0.0.1
# Self-service registration. Defaults to false in production; set true only if
# you deliberately want open sign-up. The route returns 403 when disabled.
DEEPBOX_REGISTRATION_ENABLED=false

# One-time bootstrap token to create the FIRST owner account. Set to a long
# random value on first deploy, complete first-owner setup at /, then REMOVE
# it. Only its SHA-256 hash is held in memory; the plaintext is never stored,
# logged, or echoed. Placeholder only — replace before use.
DEEPBOX_BOOTSTRAP_TOKEN=replace-with-a-long-random-one-time-value

# --- Observability & capacity (Cut 3: minimal production ops) ---
# Log verbosity for the structured JSON logger (DEBUG/INFO/WARNING/ERROR).
DEEPBOX_LOG_LEVEL=INFO
# Build provenance for deployed artifacts that ship without a .git directory
# (e.g. Azure App Service). Set to the deployed commit SHA at build time.
# Left unset locally, the server reads the commit from git directly.
DEEPBOX_GIT_COMMIT=
# Capacity thresholds. Database size is measured in MB (larger is worse);
# recording-disk FREE space is measured in MB (smaller is worse). The
# /api/admin/capacity endpoint reports ok/warn/alert against these bounds.
# Constraint: DB alert >= DB warn; disk-free alert <= disk-free warn.
DEEPBOX_DB_SIZE_WARN_MB=256
DEEPBOX_DB_SIZE_ALERT_MB=1024
DEEPBOX_DISK_FREE_WARN_MB=1024
DEEPBOX_DISK_FREE_ALERT_MB=256
